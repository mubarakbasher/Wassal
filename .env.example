# ============================================
# Wassal — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# For Docker Compose: values here override defaults in docker-compose.yml.

# ---- Database ----
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mikrotik_hotspot
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mikrotik_hotspot

# ---- JWT Secrets ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# ---- Encryption ----
# Used to encrypt MikroTik router passwords stored in the database.
# Must be exactly 32 characters.
ENCRYPTION_KEY=change-me-32-characters-exactly!

# ---- RADIUS ----
# The IP address where FreeRADIUS is reachable by MikroTik routers.
# For VPS with WireGuard: use the WG server IP (10.10.10.1) so VPN routers can reach it.
# For local dev: use your PC's LAN IP (e.g., 192.168.1.100).
# This is NOT 127.0.0.1 — your routers need to reach this IP.
RADIUS_SERVER_IP=10.10.10.1

# ---- Backend Server ----
PORT=3001

# ---- Production Deployment ----
# Domain name pointing to your VPS (used by Nginx and Let's Encrypt).
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate notifications.
CERTBOT_EMAIL=you@example.com

# ---- WireGuard VPN ----
# Enables MikroTik routers behind NAT to connect via WireGuard tunnel.
# Generate keys on VPS: wg genkey | tee /etc/wireguard/server_private.key | wg pubkey > /etc/wireguard/server_public.key
WG_SERVER_PUBLIC_KEY=
WG_SERVER_ENDPOINT=your-vps-ip:51820
