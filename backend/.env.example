# ===========================================
# Wassal Backend Configuration
# Copy this file to .env and fill in values
# ===========================================

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mikrotik_hotspot?schema=public"

# JWT Configuration
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-this-to-another-secure-random-string"
JWT_EXPIRATION="15m"
REFRESH_TOKEN_EXPIRATION="7d"

# Server Configuration
PORT=3001
NODE_ENV="development"

# Resend Email Service (for password reset emails)
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Firebase Cloud Messaging (optional - for push notifications)
# Place your Firebase service account JSON file at:
#   backend/firebase-service-account.json

# RADIUS Configuration
RADIUS_SERVER_IP=10.10.10.1
RADIUS_SECRET=changeme-radius-secret

# Encryption (for sensitive data)
ENCRYPTION_KEY=your-encryption-key-change-this

# Mikrotik Auto Password (for router provisioning)
MIKROTIK_AUTO_PASSWORD=WassalAuto2026

# WireGuard VPN
WG_SERVER_PUBLIC_KEY=your-wireguard-public-key
WG_SERVER_ENDPOINT=your-domain.com:51820
WG_PEERS_DIR=/etc/wireguard/peers

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
